# ==========================================
# Application Environment Variables Example
# ==========================================

# Database Configuration
# ------------------------------------------
# Update with your local database credentials
DB_URL=jdbc:mysql://localhost:3306/center_management?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your_db_password

# Supabase Configuration
# ------------------------------------------
# Get these from your Supabase project settings (Project Settings -> API)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Gmail SMTP Configuration
# ------------------------------------------
# Use an App Password if 2-Step Verification is enabled on your Google Account
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Admin Default Configuration
# ------------------------------------------
# Set the default admin account credentials
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=123456
ADMIN_FULLNAME=System Admin
